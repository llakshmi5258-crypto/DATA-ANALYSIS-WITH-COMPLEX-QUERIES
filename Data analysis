/* ================================
   3. DATA ANALYSIS STARTS
================================ */


/*  A. MONTHLY SALES + GROWTH (CTE + WINDOW) */
WITH MonthlySales AS (
    SELECT 
        FORMAT(order_date, 'yyyy-MM') AS month,
        SUM(amount) AS total_sales
    FROM Orders
    GROUP BY FORMAT(order_date, 'yyyy-MM')
)
SELECT 
    month,
    total_sales,
    LAG(total_sales) OVER (ORDER BY month) AS previous_month,
    (total_sales - LAG(total_sales) OVER (ORDER BY month)) AS growth
FROM MonthlySales;



/*  B. CUSTOMER RANKING (WINDOW FUNCTION) */
SELECT 
    c.customer_name,
    SUM(o.amount) AS total_spent,
    DENSE_RANK() OVER (ORDER BY SUM(o.amount) DESC) AS rank_position
FROM Customers c
JOIN Orders o ON c.customer_id = o.customer_id
GROUP BY c.customer_name;



/*  C. RUNNING TOTAL REVENUE (WINDOW FUNCTION) */
SELECT 
    order_date,
    amount,
    SUM(amount) OVER (ORDER BY order_date) AS running_total
FROM Orders;



/* D. ABOVE-AVERAGE CUSTOMERS (SUBQUERY) */
SELECT customer_name, total_spent
FROM (
    SELECT 
        c.customer_name,
        SUM(o.amount) AS total_spent
    FROM Customers c
    JOIN Orders o ON c.customer_id = o.customer_id
    GROUP BY c.customer_name
) AS sub
WHERE total_spent > (SELECT AVG(amount) FROM Orders);



/*  E. CUSTOMER BEHAVIOR ANALYSIS (CTE + CASE + WINDOW) */
WITH OrderStats AS (
    SELECT 
        customer_id,
        COUNT(*) AS total_orders,
        SUM(amount) AS total_spent
    FROM Orders
    GROUP BY customer_id
)
SELECT 
    c.customer_name,
    os.total_orders,
    os.total_spent,
    CASE 
        WHEN os.total_orders >= 3 THEN 'Loyal Customer'
        WHEN os.total_orders = 2 THEN 'Regular Customer'
        ELSE 'Occasional Customer'
    END AS customer_type,
    RANK() OVER (ORDER BY os.total_spent DESC) AS spending_rank
FROM OrderStats os
JOIN Customers c ON c.customer_id = os.customer_id;



/*  F. TOP PERFORMING MONTH (SUBQUERY) */
SELECT *
FROM (
    SELECT 
        FORMAT(order_date, 'yyyy-MM') AS month,
        SUM(amount) AS revenue
    FROM Orders
    GROUP BY FORMAT(order_date, 'yyyy-MM')
) t
WHERE revenue = (
    SELECT MAX(monthly_total)
    FROM (
        SELECT SUM(amount) AS monthly_total
        FROM Orders
        GROUP BY FORMAT(order_date, 'yyyy-MM')
    ) x
);



/* ================================
   4. FINAL INSIGHT SUMMARY QUERY
================================ */

SELECT 
    COUNT(DISTINCT customer_id) AS total_customers,
    COUNT(order_id) AS total_orders,
    SUM(amount) AS total_revenue,
    AVG(amount) AS avg_order_value
FROM Orders;
